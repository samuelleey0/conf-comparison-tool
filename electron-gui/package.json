{
  "name": "electron-gui",
  "version": "1.0.0",
  "description": "Frontend desktop app for Automated Cisco Configuration & Marking System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:backend": "powershell -ExecutionPolicy Bypass -File ./scripts/build-backend.ps1",
    "build:backend:linux": "bash ./scripts/build-backend.sh",
    "build:installer": "npm run build:backend && electron-builder --win nsis",
    "build:installer:ubuntu": "npm run build:backend:linux && electron-builder --linux AppImage deb",
    "install:ubuntu": "bash ./scripts/install-ubuntu.sh",
    "uninstall:ubuntu": "bash ./scripts/uninstall-ubuntu.sh",
    "build:portable": "npm run build:backend && electron-builder --win portable",
    "build:windows": "npm run build:backend && electron-builder --win nsis portable",
    "build:linux": "npm run build:installer:ubuntu"
  },
  "keywords": [
    "electron",
    "python",
    "cisco",
    "automation",
    "flask"
  ],
  "author": "ICT30018 2026_S1 FYP ConfigSphere Team",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^38.2.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.cisco.config-tool",
    "productName": "Cisco Config Comparison Tool",
    "directories": {
      "buildResources": "assets"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cisco Config Tool"
    },
    "files": [
      "*.js",
      "*.html",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "backend-dist/conf-comparison-server",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
