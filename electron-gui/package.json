{
  "name": "electron-gui",
  "version": "1.0.0",
  "description": "Frontend desktop app for Automated Cisco Marking System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },
  "keywords": [
    "electron",
    "python",
    "cisco",
    "automation",
    "flask"
  ],
  "author": "Khant and Team",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^38.2.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.cisco.config-tool",
    "productName": "Cisco Config Comparison Tool",
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cisco Config Tool"
    },
    "files": [
      "main.js",
      "renderer.js",
      "windows-serial.js",
      "*.html",
      "assets/**/*",
      "node_modules/**/*"
    ]
  }
}
